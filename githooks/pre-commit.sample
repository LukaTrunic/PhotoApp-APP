#!/bin/sh
# LO7 sample pre-commit hook — run fast tests before commit.
# Install: git config core.hooksPath githooks && cp githooks/pre-commit.sample githooks/pre-commit

echo "Running CI test profile before commit..."
mvn -B -ntp test -Pci -q
status=$?

if [ $status -ne 0 ]; then
  echo "Pre-commit tests failed. Commit aborted."
  exit 1
fi

exit 0
